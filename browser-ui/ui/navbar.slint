import { ProIcon, ChromeNavButton } from "common.slint";

export component Navbar inherits Rectangle {
    in-out property <string> current-url;
    in property <bool> has-titlebar-spacing: true;
    in property <bool> shields-active: true;

    callback navigate_to(string);
    callback toggle_shields();
    callback toggle_downloads();
    callback back_clicked();
    callback forward_clicked();
    callback reload_clicked();
    callback toggle_layout();

    height: 40px;
    background: #2B2D31;

    HorizontalLayout {
        padding-left: root.has-titlebar-spacing ? 80px : 12px; // Align with TabBar if no TabBar is present
        padding-right: 12px;
        spacing: 12px;

        // 1. Left Section: Navigation controls
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 4px;

                ChromeNavButton {
                    icon: @image-url("icons/solar/arc.svg");
                    activated => { }
                }

                ChromeNavButton {
                    icon: @image-url("icons/solar/arrow-left.svg");
                    activated => { root.back_clicked(); }
                }

                ChromeNavButton {
                    icon: @image-url("icons/solar/arrow-right.svg");
                    activated => { root.forward_clicked(); }
                }

                ChromeNavButton {
                    icon: @image-url("icons/solar/refresh.svg");
                    activated => { root.reload_clicked(); }
                }
            }
        }

        // 2. Middle Section: URL Search Bar
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Rectangle {
                height: 32px;
                background: text-input.has-focus ? #2C2D30 : #1E1F22; // Darker background for URL
                border-radius: 16px; // Full pill shape for URL input
                border-width: 1px;
                border-color: text-input.has-focus ? #00F0FF : #3F3F46;
                clip: true;

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 6px;
                    spacing: 8px;

                    // Google Favicon + Dropdown Arrow
                    HorizontalLayout {
                        spacing: 2px;
                        horizontal-stretch: 0;
                        y: (parent.height - self.height) / 2;
                        ProIcon {
                            icon: @image-url("icons/solar/google.svg");
                            icon-color: #FFFFFF;
                            fill-color: #FFFFFF;
                            icon-width: 14px;
                            icon-height: 14px;
                            stroke-width: 1.0px;
                        }
                        Text {
                            text: "▾";
                            color: #9CA3AF;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                    }

                    // Divider line
                    Rectangle {
                        width: 1px;
                        height: 14px;
                        background: #3F3F46;
                        y: (parent.height - self.height) / 2;
                    }

                    ProIcon {
                        icon: @image-url("icons/solar/lock.svg");
                        icon-color: #9CA3AF;
                        icon-width: 14px;
                        icon-height: 14px;
                        stroke-width: 1.6px;
                        y: (parent.height - self.height) / 2;
                    }

                    text-input := TextInput {
                        text: root.current-url == "about:newtab" ? "" : root.current-url;
                        color: #FFFFFF;
                        font-size: 12px;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        accepted => {
                            root.navigate_to(self.text);
                        }
                    }

                    if (text-input.text == "" || root.current-url == "about:newtab") && !text-input.has-focus : Text {
                        text: "ค้นหาด้วย Google หรือป้อนที่อยู่...";
                        color: #9CA3AF;
                        font-size: 11px;
                        vertical-alignment: center;
                    }

                    // Shields button inside URL Area
                    Rectangle {
                        width: 26px;
                        height: 26px;
                        border-radius: 13px;
                        background: touch-shields.has-hover ? #FFFFFF15 : (root.shields-active ? #EF444415 : transparent);
                        y: (parent.height - self.height) / 2;
                        
                        ProIcon {
                            icon: @image-url("icons/solar/shield.svg");
                            icon-color: root.shields-active ? #EF4444 : #9CA3AF;
                            icon-width: 14px;
                            icon-height: 14px;
                            stroke-width: 1.6px;
                            y: (parent.height - self.height) / 2;
                        }

                        touch-shields := TouchArea {
                            clicked => { root.toggle_shields(); }
                        }
                    }
                }
            }
        }

        // 3. Right Section: Toolbar controls
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 4px;

                ChromeNavButton {
                    icon: @image-url("icons/solar/download.svg");
                    activated => { root.toggle_downloads(); }
                }

                ChromeNavButton {
                    icon: @image-url("icons/solar/document.svg");
                    activated => { }
                }

                ChromeNavButton {
                    icon: @image-url("icons/solar/person.svg");
                    activated => { }
                }

                ChromeNavButton {
                    icon: @image-url("icons/solar/menu.svg");
                    activated => { root.toggle_layout(); }
                }
            }
        }
    }
}
