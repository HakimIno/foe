import { ProIcon, GlassButton } from "common.slint";

export component Navbar inherits Rectangle {
    in-out property <string> current-url;
    in property <bool> has-titlebar-spacing: true;
    in property <bool> shields-active: true;

    callback navigate_to(string);
    callback toggle_shields();
    callback toggle_downloads();
    callback back_clicked();
    callback forward_clicked();
    callback reload_clicked();
    callback toggle_layout();

    height: 40px;
    // iOS 27 Liquid Glass — พื้นดำสนิท ปุ่มลอยอิสระ ไม่มีกล่องครอบ
    background: @linear-gradient(180deg, #0E0E11 0%, #060607 100%);

    HorizontalLayout {
        padding-left: root.has-titlebar-spacing ? 80px : 10px;
        padding-right: 10px;
        spacing: 8px;

        // 1. Left: navigation buttons — ลอยอิสระ ไม่มีกล่อง
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 0;
            HorizontalLayout {
                spacing: 2px;

                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/arc.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/arrow-left.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { root.back_clicked(); }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/arrow-right.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { root.forward_clicked(); }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/refresh.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { root.reload_clicked(); }
                }
            }
        }

        // 2. Middle: URL field — พื้นนุ่ม ไม่มีขอบคม (ลอยบนพื้นดำ)
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Rectangle {
                height: 34px;
                border-radius: self.height / 2; // full pill
                background: text-input.has-focus ? #FFFFFF1F : #FFFFFF12;

                animate background { duration: 160ms; easing: ease-out; }

                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 6px;
                    spacing: 9px;

                    // Search engine chip (Google + dropdown)
                    HorizontalLayout {
                        spacing: 3px;
                        horizontal-stretch: 0;
                        y: (parent.height - self.height) / 2;
                        ProIcon {
                            icon: @image-url("icons/solar/google.svg");
                            icon-color: #FFFFFF;
                            fill-color: #FFFFFF;
                            icon-width: 15px;
                            icon-height: 15px;
                            stroke-width: 1.0px;
                        }
                        Text {
                            text: "▾";
                            color: #FFFFFF7A;
                            font-size: 9px;
                            vertical-alignment: center;
                        }
                    }

                    // Divider line — จางมาก
                    Rectangle {
                        width: 1px;
                        height: 16px;
                        background: #FFFFFF1F;
                        y: (parent.height - self.height) / 2;
                    }

                    ProIcon {
                        icon: @image-url("icons/solar/lock.svg");
                        icon-color: #30D158; // secure-green tint (iOS)
                        icon-width: 13px;
                        icon-height: 13px;
                        stroke-width: 1.6px;
                        y: (parent.height - self.height) / 2;
                    }

                    text-input := TextInput {
                        text: root.current-url == "about:newtab" ? "" : root.current-url;
                        color: #FFFFFF;
                        font-size: 12.5px;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        accepted => {
                            root.navigate_to(self.text);
                        }
                    }

                    if (text-input.text == "" || root.current-url == "about:newtab") && !text-input.has-focus : Text {
                        text: "ค้นหาด้วย Google หรือป้อนที่อยู่...";
                        color: #FFFFFF6E;
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    // Shields button inside URL field
                    GlassButton {
                        width: 28px;
                        height: 28px;
                        icon-size: 15px;
                        icon: @image-url("icons/solar/shield.svg");
                        icon-color: root.shields-active ? #FF453A : #FFFFFF82;
                        icon-hover-color: root.shields-active ? #FF453A : #FFFFFF;
                        hover-bg: #FFFFFF16;
                        pressed-bg: #FFFFFF24;
                        y: (parent.height - self.height) / 2;
                        activated => { root.toggle_shields(); }
                    }
                }
            }
        }

        // 3. Right: tools buttons — ลอยอิสระ ไม่มีกล่อง
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 0;
            HorizontalLayout {
                spacing: 2px;

                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/download.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { root.toggle_downloads(); }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/document.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/person.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/solar/menu.svg");
                    icon-color: #FFFFFFA6;
                    hover-bg: #FFFFFF16;
                    pressed-bg: #FFFFFF26;
                    activated => { root.toggle_layout(); }
                }
            }
        }
    }
}
