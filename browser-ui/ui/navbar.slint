import { ProIcon, GlassButton } from "common.slint";
import { Theme } from "theme.slint";

export component Navbar inherits Rectangle {
    in-out property <string> current-url;
    in property <bool> has-titlebar-spacing: true;
    in property <bool> shields-active: true;

    callback navigate_to(string);
    callback toggle_shields();
    callback toggle_downloads();
    callback back_clicked();
    callback forward_clicked();
    callback reload_clicked();
    callback toggle_layout();

    height: 40px;
    // Flat toolbar — light = ขาว, dark = เทาเข้ม
    background: Theme.toolbar;

    // เมื่อ current-url เปลี่ยนจากภายนอก (เปิดแท็บใหม่/สลับแท็บ/นำทางเสร็จ) ต้อง
    // เซ็ต text ของ TextInput ใหม่เอง — เพราะพอผู้ใช้พิมพ์ binding "text:" เดิมจะถูก
    // แทนที่ด้วยค่าที่พิมพ์ (binding ตาย) ค่าเก่าจึงค้างถ้าไม่ reset ตรงนี้
    changed current-url => {
        text-input.text = root.current-url == "about:newtab" ? "" : root.current-url;
    }

    HorizontalLayout {
        padding-left: root.has-titlebar-spacing ? 80px : 10px;
        padding-right: 10px;
        spacing: 8px;

        // 1. Left: navigation buttons — ลอยอิสระ ไม่มีกล่อง
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 0;
            HorizontalLayout {
                spacing: 2px;

                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/iconoir--nav-arrow-left.svg");
                    icon-color: Theme.glass-icon;
                    hover-bg: Theme.glass-hover-bg;
                    pressed-bg: Theme.glass-pressed-bg;
                    activated => { root.back_clicked(); }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/iconoir--nav-arrow-right.svg");
                    icon-color: Theme.glass-icon;
                    hover-bg: Theme.glass-hover-bg;
                    pressed-bg: Theme.glass-pressed-bg;
                    activated => { root.forward_clicked(); }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/iconoir--refresh.svg");
                    icon-color: Theme.glass-icon;
                    hover-bg: Theme.glass-hover-bg;
                    pressed-bg: Theme.glass-pressed-bg;
                    activated => { root.reload_clicked(); }
                }
            }
        }

        // 2. Middle: URL field — พื้นนุ่ม ไม่มีขอบคม (ลอยบนพื้นดำ)
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Rectangle {
                height: 32px;
                border-radius: self.height / 2; // full pill
                background: text-input.has-focus ? Theme.url-bg-focus : Theme.url-bg;
                // Focused omnibox: thin, clear Chrome-blue outline like the reference.
                border-width: text-input.has-focus ? 1px : 0px;
                border-color: Theme.selection;
                drop-shadow-blur: 0px;

                animate background { duration: 160ms; easing: ease-out; }

                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 6px;
                    spacing: 7px;

                    ProIcon {
                        icon: @image-url("icons/iconoir--lock.svg");
                        icon-color: Theme.glass-icon-strong;
                        icon-width: 15px;
                        icon-height: 15px;
                        stroke-width: 1.5px;
                        background: text-input.has-focus ? Theme.url-bg  : Theme.url-bg-focus;
                        border-radius: parent.width /2;
                        y: (parent.height - self.height) / 2;
                    }

                    input-wrap := Rectangle {
                        background: transparent;
                        horizontal-stretch: 1;

                        text-input := TextInput {
                            width: parent.width;
                            height: parent.height;
                            text: root.current-url == "about:newtab" ? "" : root.current-url;
                            color: Theme.url-text;
                            font-size: 13px;
                            font-weight: 500;
                            vertical-alignment: center;
                            accepted => {
                                root.navigate_to(self.text);
                            }
                        }

                        if (text-input.text == "" || root.current-url == "about:newtab") && !text-input.has-focus : Text {
                            x: 0px;
                            y: 0px;
                            width: parent.width;
                            height: parent.height;
                            text: "ค้นหาด้วย Google หรือป้อนที่อยู่";
                            color: Theme.url-placeholder;
                            font-size: 13px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    // Shields button inside URL field
                    GlassButton {
                        width: 28px;
                        height: 28px;
                        icon-size: 15px;
                        icon: @image-url("icons/iconoir--bright-star.svg");
                        icon-color: Theme.glass-icon-strong;
                        border-radius: parent.height / 2;
                        background: text-input.has-focus ? Theme.url-bg  : Theme.url-bg-focus;
                        y: (parent.height - self.height) / 2;
                        activated => { root.toggle_shields(); }
                    }
                }
            }
        }

        // 3. Right: tools buttons — ลอยอิสระ ไม่มีกล่อง
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 0;
            HorizontalLayout {
                spacing: 2px;

                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/iconoir--cloud-download.svg");
                    icon-color: Theme.glass-icon;
                    hover-bg: Theme.glass-hover-bg;
                    pressed-bg: Theme.glass-pressed-bg;
                    activated => { root.toggle_downloads(); }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/iconoir--user.svg");
                    icon-color: Theme.glass-icon;
                    hover-bg: Theme.glass-hover-bg;
                    pressed-bg: Theme.glass-pressed-bg;
                    activated => { }
                }
                GlassButton {
                    width: 30px;
                    height: 30px;
                    icon-size: 16px;
                    icon: @image-url("icons/iconoir--menu.svg");
                    icon-color: Theme.glass-icon;
                    hover-bg: Theme.glass-hover-bg;
                    pressed-bg: Theme.glass-pressed-bg;
                    activated => { root.toggle_layout(); }
                }
            }
        }
    }
}
