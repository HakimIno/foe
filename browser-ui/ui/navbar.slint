import { ProIcon, ProIconKind, ChromeNavButton } from "common.slint";

export component Navbar inherits Rectangle {
    in-out property <string> current-url;
    in property <bool> has-titlebar-spacing: true;
    in property <bool> shields-active: true;

    callback navigate_to(string);
    callback toggle_shields();
    callback toggle_downloads();
    callback back_clicked();
    callback forward_clicked();
    callback reload_clicked();

    height: 36px; /* 36px height to maintain 76px logical height (40px + 36px) */
    background: #1E1F22; /* Unified dark window background */

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;

        // 1. Left Section: Navigation controls (Vertically Centered)
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 4px;

                // Sidebar Toggle panel button (Arc icon represents panels)
                ChromeNavButton {
                    icon: ProIconKind.Arc;
                    activated => { }
                }

                ChromeNavButton {
                    icon: ProIconKind.ArrowLeft;
                    activated => { root.back_clicked(); }
                }

                ChromeNavButton {
                    icon: ProIconKind.ArrowRight;
                    activated => { root.forward_clicked(); }
                }

                ChromeNavButton {
                    icon: ProIconKind.ArrowClockwise;
                    activated => { root.reload_clicked(); }
                }
            }
        }

        // 2. Middle Section: URL Search Bar (Vertically Centered)
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Rectangle {
                height: 28px;
                background: #2C2D30; /* Lighter container background */
                border-radius: 8px; /* Smooth Firefox roundness */
                border-width: 1.5px;
                border-color: text-input.has-focus ? #00F0FF : #3F3F46; /* Cyan glowing border on focus */
                clip: true;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 6px;
                    spacing: 8px;

                    // Google Favicon + Dropdown Arrow (Firefox style)
                    HorizontalLayout {
                        spacing: 2px;
                        horizontal-stretch: 0; /* Prevent container from stretching */
                        y: (parent.height - self.height) / 2;
                        ProIcon {
                            icon: ProIconKind.Google;
                            icon-color: #FFFFFF;
                            fill-color: #FFFFFF;
                            icon-width: 14px;
                            icon-height: 14px;
                            stroke-width: 1.0px;
                        }
                        Text {
                            text: "▾";
                            color: #9CA3AF;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                    }

                    // Divider line
                    Rectangle {
                        width: 1px;
                        height: 14px;
                        background: #3F3F46;
                        y: (parent.height - self.height) / 2;
                    }

                    ProIcon {
                        icon: ProIconKind.Lock;
                        icon-color: #9CA3AF;
                        icon-width: 14px;
                        icon-height: 14px;
                        stroke-width: 1.6px;
                        y: (parent.height - self.height) / 2;
                    }

                    text-input := TextInput {
                        text: root.current-url == "about:newtab" ? "" : root.current-url;
                        color: #FFFFFF;
                        font-size: 12px;
                        font-weight: 500;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        accepted => {
                            root.navigate_to(self.text);
                        }
                    }

                    if (text-input.text == "" || root.current-url == "about:newtab") && !text-input.has-focus : Text {
                        text: "ค้นหาด้วย Google หรือป้อนที่อยู่...";
                        color: #9CA3AF;
                        font-size: 11px;
                        vertical-alignment: center;
                    }

                    // Shields button inside URL Area
                    Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 11px;
                        background: touch-shields.has-hover ? #FFFFFF15 : (root.shields-active ? #EF444415 : transparent);
                        y: (parent.height - self.height) / 2;
                        
                        ProIcon {
                            icon: ProIconKind.Shield;
                            icon-color: root.shields-active ? #EF4444 : #9CA3AF;
                            icon-width: 14px;
                            icon-height: 14px;
                            stroke-width: 1.6px;
                            y: (parent.height - self.height) / 2;
                        }

                        touch-shields := TouchArea {
                            clicked => { root.toggle_shields(); }
                        }
                    }
                }
            }
        }

        // 3. Right Section: Toolbar controls (Vertically Centered)
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 4px;

                ChromeNavButton {
                    icon: ProIconKind.ArrowDownload;
                    activated => { root.toggle_downloads(); }
                }

                ChromeNavButton {
                    icon: ProIconKind.Document;
                    activated => { }
                }

                ChromeNavButton {
                    icon: ProIconKind.Person;
                    activated => { }
                }

                ChromeNavButton {
                    icon: ProIconKind.Menu;
                    activated => { }
                }
            }
        }
    }
}
