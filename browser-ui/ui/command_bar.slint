import { ProIcon } from "common.slint";
import { Theme } from "theme.slint";

export component CommandBar inherits Rectangle {
    in-out property <string> command-text;
    callback submit(string);
    callback dismiss();

    background: Theme.overlay;

    TouchArea {
        clicked => { root.dismiss(); }
    }

    Rectangle {
        width: 480px;
        height: 52px;
        background: Theme.popover-bg;
        border-radius: 6px;
        border-width: 1px;
        border-color: Theme.popover-border;
        y: 120px;
        
        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            spacing: 12px;

            ProIcon {
                icon: @image-url("icons/solar/search.svg");
                icon-color: Theme.text-muted;
                icon-width: 16px;
                icon-height: 16px;
                stroke-width: 1.6px;
                y: (parent.height - self.height) / 2;
            }

            TextInput {
                text: root.command-text;
                color: Theme.text;
                font-size: 14px;
                vertical-alignment: center;
                accepted => {
                    root.submit(self.text);
                }
            }
        }
    }
}
