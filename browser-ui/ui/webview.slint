import { ProIcon } from "common.slint";

component FeatureHint inherits HorizontalLayout {
    in property <image> icon;
    in property <string> label;

    spacing: 5px;
    alignment: center;

    ProIcon {
        icon: root.icon;
        icon-color: #52525B;
        icon-width: 11px;
        icon-height: 11px;
        stroke-width: 1.4px;
        width: 14px;
        height: 14px;
    }

    Text {
        text: root.label;
        color: #52525B;
        font-size: 11px;
        font-weight: 500;
        vertical-alignment: center;
    }
}

component HintDivider inherits Rectangle {
    width: 1px;
    height: 10px;
    background: #3A3B3E;
}

export component Webview inherits Rectangle {
    in property <string> current-url;
    in property <string> current-title;
    in property <image> frame;

    callback search_submitted(string);

    background: (current-url == "about:newtab" || current-url == "about:blank" || current-url == "") ? #1E1F22 : #FFFFFF;

    if current-url != "about:newtab" && current-url != "about:blank" && current-url != "" : Image {
        source: frame;
        width: 100%;
        height: 100%;
        image-fit: fill;
    }

    if current-url == "about:newtab" || current-url == "about:blank" || current-url == "" : VerticalLayout {
        alignment: center;

        VerticalLayout {
            alignment: center;
            spacing: 8px;
            padding-bottom: 36px;

            Text {
                text: "foe";
                color: #FAFAFA;
                font-size: 44px;
                font-weight: 700;
                letter-spacing: -1.5px;
                horizontal-alignment: center;
            }

            Text {
                text: "สืบค้น";
                color: #71717A;
                font-size: 11px;
                font-weight: 500;
                letter-spacing: 10px;
                horizontal-alignment: center;
            }
        }

        HorizontalLayout {
            alignment: center;
            padding-bottom: 24px;

            Rectangle {
                width: 540px;
                height: 44px;
                background: search-input.has-focus ? #323338 : #2C2D30;
                border-radius: 11px;
                border-width: 1px;
                border-color: search-input.has-focus ? #52525B : #3A3B3E;

                animate background { duration: 150ms; }
                animate border-color { duration: 150ms; }

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 12px;

                    ProIcon {
                        icon: @image-url("icons/solar/search.svg");
                        icon-color: search-input.has-focus ? #A1A1AA : #71717A;
                        icon-width: 15px;
                        icon-height: 15px;
                        stroke-width: 1.6px;
                        y: (parent.height - self.height) / 2;
                    }

                    search-input := TextInput {
                        text: "";
                        color: #FAFAFA;
                        font-size: 14px;
                        font-weight: 400;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        accepted => {
                            root.search_submitted(self.text);
                        }
                    }

                    if search-input.text == "" && !search-input.has-focus : Text {
                        text: "ค้นหาหรือป้อนที่อยู่เว็บ";
                        color: #52525B;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        HorizontalLayout {
            alignment: center;
            spacing: 14px;

            FeatureHint {
                icon: @image-url("icons/solar/shield.svg");
                label: "Shields เปิดอยู่";
            }

            HintDivider {}

            FeatureHint {
                icon: @image-url("icons/solar/lock.svg");
                label: "ไม่บันทึกประวัติ";
            }

            HintDivider {}

            Text {
                text: "ไม่ติดตาม";
                color: #52525B;
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }
    }
}
