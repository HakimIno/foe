import { ProIcon, ProIconKind } from "common.slint";

export component Webview inherits Rectangle {
    in property <string> current-url;
    in property <string> current-title;
    in property <image> frame;

    callback search_submitted(string);

    background: #FFFFFF;

    if current-url != "about:newtab" && current-url != "about:blank" && current-url != "" : Image {
        source: frame;
        width: 100%;
        height: 100%;
        image-fit: fill;
    }

    if current-url == "about:newtab" || current-url == "about:blank" || current-url == "" : VerticalLayout {
        alignment: center;
        spacing: 28px;

        Text {
            text: "Google";
            color: #4285F4;
            font-size: 56px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            alignment: center;

            Rectangle {
                width: 520px;
                height: 46px;
                background: #FFFFFF;
                border-radius: 23px;
                border-width: 1px;
                border-color: #DFE1E5;

                HorizontalLayout {
                    padding-left: 18px;
                    padding-right: 18px;
                    spacing: 12px;

                    ProIcon {
                        icon: ProIconKind.Search;
                        icon-color: #9AA0A6;
                        icon-width: 16px;
                        icon-height: 16px;
                        stroke-width: 1.5px;
                        y: (parent.height - self.height) / 2;
                    }

                    search-input := TextInput {
                        text: "";
                        color: #202124;
                        font-size: 14px;
                        font-weight: 400;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        accepted => {
                            root.search_submitted(self.text);
                        }
                    }

                    if search-input.text == "" && !search-input.has-focus : Text {
                        text: "Search Google or type a URL";
                        color: #9AA0A6;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
