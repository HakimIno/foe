import { Theme } from "theme.slint";

export component ProIcon inherits Rectangle {
    in property <image> icon;
    in property <color> icon-color: Theme.text-muted;
    in property <length> icon-width: 15px;
    in property <length> icon-height: 15px;
    in property <length> stroke-width: 1.6px;
    in property <color> fill-color: transparent;

    width: 24px;
    height: 24px;

    Image {
        width: root.icon-width;
        height: root.icon-height;
        source: root.icon;
        colorize: root.icon-color;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

export component MinimalIconButton inherits Rectangle {
    in property <image> icon;
    in property <color> active-color: Theme.text;
    in property <color> inactive-color: Theme.text-muted;
    in property <bool> active: false;
    in property <length> icon-width: 14px;
    in property <length> icon-height: 14px;
    in property <length> stroke-width: 1.5px;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 14px;
    background: touch-area.has-hover ? Theme.control-hover : transparent;

    animate background { duration: 100ms; }

    ProIcon {
        icon: root.icon;
        icon-color: root.active ? root.active-color : (touch-area.has-hover ? Theme.text : root.inactive-color);
        icon-width: root.icon-width;
        icon-height: root.icon-height;
        stroke-width: root.stroke-width;
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component MinimalButton inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked();

    height: 28px;
    border-radius: 14px;
    background: root.active ? Theme.surface-active : (touch-area.has-hover ? Theme.control-hover : transparent);
    border-width: 1px;
    border-color: root.active ? Theme.surface-border : (touch-area.has-hover ? Theme.surface-border : transparent);

    animate background { duration: 100ms; }

    Text {
        text: root.text;
        color: root.active ? Theme.text : Theme.text-muted;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component ChromeNavButton inherits Rectangle {
    in property <image> icon;
    callback activated();

    width: 28px;
    height: 28px;
    border-radius: 14px;
    background: touch-area.has-hover ? Theme.add-tab-hover : transparent;

    ProIcon {
        icon: root.icon;
        icon-color: touch-area.has-hover ? Theme.glass-icon-strong : Theme.glass-icon;
        icon-width: 15px;  /* Enlarged from 11px for crisp visibility */
        icon-height: 15px; /* Enlarged from 11px for crisp visibility */
        stroke-width: 1.6px;
        y: (parent.height - self.height) / 2;
    }

    touch-area := TouchArea {
        clicked => { root.activated(); }
    }
}

// iOS 26 / macOS 26 "Liquid Glass" capsule button — โปร่งแสง, hover/press
// brighten ตัวเอง, วางอยู่ภายใน GlassCapsule ได้พอดี (default transparent fill)
export component GlassButton inherits Rectangle {
    in property <image> icon;
    in property <color> icon-color: Theme.glass-icon;
    in property <color> icon-hover-color: Theme.glass-icon-strong;
    in property <color> hover-bg: Theme.glass-hover-bg;
    in property <color> pressed-bg: Theme.glass-pressed-bg;
    in property <length> icon-size: 15px;
    callback activated();

    width: 28px;
    height: 28px;
    border-radius: self.height / 2;
    background: touch.pressed
        ? root.pressed-bg
        : (touch.has-hover ? root.hover-bg : transparent);

    animate background { duration: 130ms; easing: ease-out; }

    Image {
        width: root.icon-size;
        height: root.icon-size;
        source: root.icon;
        colorize: touch.has-hover ? root.icon-hover-color : root.icon-color;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        animate colorize { duration: 130ms; }
    }

    touch := TouchArea {
        clicked => { root.activated(); }
    }
}

// Liquid Glass capsule — แคปซูลกระจกฝ้าลอยตัว มี specular sheen ด้านบน
// + เงานุ่ม สำหรับห่อกลุ่มปุ่ม (ใส่ HorizontalLayout เป็น children)
export component GlassCapsule inherits Rectangle {
    // themeable — default = dark glass; navbar override เป็น light glass
    in property <brush> fill: @linear-gradient(180deg, #FFFFFF16 0%, #FFFFFF06 100%);
    in property <color> stroke: #FFFFFF22;
    in property <brush> sheen: @linear-gradient(180deg, #FFFFFF14 0%, #FFFFFF00 100%);
    in property <color> shadow-color: #00000033;
    in property <length> shadow-blur: 8px;

    border-radius: self.height / 2;
    background: root.fill;
    border-width: 1px;
    border-color: root.stroke;
    drop-shadow-blur: root.shadow-blur;
    drop-shadow-color: root.shadow-color;
    drop-shadow-offset-y: 2px;
    clip: true;

    // specular top sheen — เส้นแสงไฮไลต์ครึ่งบนแบบกระจก
    Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: parent.height / 2;
        background: root.sheen;
    }

    @children
}

// Decorative scalloped (sine-wave) edge — ทำเป็นแถบเส้นหยักสีขาวสำหรับวางคั่น
// ระหว่าง chrome สีน้ำเงินกับ webview (สไตล์ Arc). วาดด้วย Path tile ต่อ
// period ละ 16px แล้ว repeat ให้เต็มความกว้าง (responsive ตาม resize).
export component WavyEdge inherits Rectangle {
    in property <brush> line-color: #FFFFFFDE;
    in property <length> stroke-w: 1.5px;

    height: 12px;
    clip: true;

    // +1 tile กันขอบขวาว่างตอนหารไม่ลงตัว
    property <int> tile-count: Math.ceil(self.width / 16px) + 1;

    for i in root.tile-count : Path {
        x: i * 16px;
        y: 0px;
        width: 16px;
        height: parent.height;
        viewbox-width: 16;
        viewbox-height: 12;
        fill: transparent;
        stroke: root.line-color;
        stroke-width: root.stroke-w;

        // หนึ่ง period ของคลื่น แนบขอบล่างของแถบ (แกนกลาง y=8.5 จาก 12) ให้เส้น
        // ไปอยู่ติดรอยต่อ chrome↔webview ไม่ลอยกลางแถบ — amplitude ~2.5px
        MoveTo { x: 0; y: 8.5; }
        QuadraticTo { control-x: 4; control-y: 3.5; x: 8; y: 8.5; }
        QuadraticTo { control-x: 12; control-y: 13.5; x: 16; y: 8.5; }
    }
}
