export component ProIcon inherits Rectangle {
    in property <image> icon;
    in property <color> icon-color: #71717A;
    in property <length> icon-width: 15px;
    in property <length> icon-height: 15px;
    in property <length> stroke-width: 1.6px;
    in property <color> fill-color: transparent;

    width: 24px;
    height: 24px;

    Image {
        width: root.icon-width;
        height: root.icon-height;
        source: root.icon;
        colorize: root.icon-color;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

export component MinimalIconButton inherits Rectangle {
    in property <image> icon;
    in property <color> active-color: #18181B;
    in property <color> inactive-color: #71717A;
    in property <bool> active: false;
    in property <length> icon-width: 14px;
    in property <length> icon-height: 14px;
    in property <length> stroke-width: 1.5px;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 14px;
    background: touch-area.has-hover ? #E4E4E7A0 : transparent;

    animate background { duration: 100ms; }

    ProIcon {
        icon: root.icon;
        icon-color: root.active ? root.active-color : (touch-area.has-hover ? #18181B : root.inactive-color);
        icon-width: root.icon-width;
        icon-height: root.icon-height;
        stroke-width: root.stroke-width;
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component MinimalButton inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked();

    height: 28px;
    border-radius: 14px;
    background: root.active ? #FFFFFF : (touch-area.has-hover ? #E4E4E7A0 : transparent);
    border-width: 1px;
    border-color: root.active ? #D4D4D8 : (touch-area.has-hover ? #E4E4E7 : transparent);

    animate background { duration: 100ms; }

    Text {
        text: root.text;
        color: root.active ? #18181B : #71717A;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component ChromeNavButton inherits Rectangle {
    in property <image> icon;
    callback activated();

    width: 28px;
    height: 28px;
    border-radius: 14px;
    background: touch-area.has-hover ? #FFFFFF22 : transparent;

    ProIcon {
        icon: root.icon;
        icon-color: touch-area.has-hover ? #FFFFFF : #FFFFFFC4;
        icon-width: 15px;  /* Enlarged from 11px for crisp visibility */
        icon-height: 15px; /* Enlarged from 11px for crisp visibility */
        stroke-width: 1.6px;
        y: (parent.height - self.height) / 2;
    }

    touch-area := TouchArea {
        clicked => { root.activated(); }
    }
}

// Decorative scalloped (sine-wave) edge — ทำเป็นแถบเส้นหยักสีขาวสำหรับวางคั่น
// ระหว่าง chrome สีน้ำเงินกับ webview (สไตล์ Arc). วาดด้วย Path tile ต่อ
// period ละ 16px แล้ว repeat ให้เต็มความกว้าง (responsive ตาม resize).
export component WavyEdge inherits Rectangle {
    in property <brush> line-color: #FFFFFFDE;
    in property <length> stroke-w: 1.5px;

    height: 12px;
    clip: true;

    // +1 tile กันขอบขวาว่างตอนหารไม่ลงตัว
    property <int> tile-count: Math.ceil(self.width / 16px) + 1;

    for i in root.tile-count : Path {
        x: i * 16px;
        y: 0px;
        width: 16px;
        height: parent.height;
        viewbox-width: 16;
        viewbox-height: 12;
        fill: transparent;
        stroke: root.line-color;
        stroke-width: root.stroke-w;

        // หนึ่ง period ของคลื่น แนบขอบล่างของแถบ (แกนกลาง y=8.5 จาก 12) ให้เส้น
        // ไปอยู่ติดรอยต่อ chrome↔webview ไม่ลอยกลางแถบ — amplitude ~2.5px
        MoveTo { x: 0; y: 8.5; }
        QuadraticTo { control-x: 4; control-y: 3.5; x: 8; y: 8.5; }
        QuadraticTo { control-x: 12; control-y: 13.5; x: 16; y: 8.5; }
    }
}
