import { ProIcon, MinimalIconButton, ChromeNavButton } from "common.slint";
import { TabInfo } from "sidebar.slint";

export struct TabDragState {
    from: int,
    to: int,
    delta-x: length,
    active: bool,
}

export global TabDrag {
   
    in-out property <TabDragState> state: { from: -1, to: -1, delta-x: 0px, active: false };
    // Locks out tab-drag processing once vertical window-drag has been initiated
    in-out property <bool> window-drag-mode: false;
}

component TabGhost inherits Rectangle {
    in property <string> title;
    in property <string> site-type;
    in property <bool> active;
    in property <length> slot-width;

    in property <bool> has-favicon;
    in property <image> favicon;

    width: root.slot-width;
    height: 30px; /* Compact floating tab */
    opacity: 0.85;

    // Dragged copy — แสดงเป็น pill เด่นเสมอ
    background_capsule := Rectangle {
        x: 4px;
        y: 2px;
        width: parent.width - 8px;
        height: parent.height - 4px;
        border-radius: 7px;
        background: #FFFFFF3D;
        border-width: 0px;

        drop-shadow-color: #00000040;
        drop-shadow-blur: 5px;
        drop-shadow-offset-y: 1px;
    }


    HorizontalLayout {
        padding-left: root.slot-width > 70px ? 14px : 4px;
        padding-right: root.slot-width > 70px ? 10px : 4px;
        spacing: root.slot-width > 70px ? 8px : 0px;

        ProIcon {
            icon: root.has-favicon ? root.favicon : (
                root.site-type == "brave" ? @image-url("icons/solar/shield.svg") :
                root.site-type == "arc" ? @image-url("icons/solar/arc.svg") :
                root.site-type == "google" ? @image-url("icons/solar/google.svg") :
                @image-url("icons/solar/globe.svg")
            );
            icon-color: root.has-favicon ? #FFFFFF : #FFFFFF;
            fill-color: (!root.has-favicon && root.site-type == "google") ? #FFFFFF : transparent;
            icon-width: 13px;
            icon-height: 13px;
            stroke-width: 1.6px;
            y: (parent.height - self.height) / 2;
        }

        if root.slot-width > 70px : Text {
            text: root.title;
            color: #FFFFFF;
            font-size: 11px;
            font-weight: root.active ? 600 : 500;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
    }
}

// โทนข้อความ/ไอคอนของ tab บนพื้นน้ำเงิน: active = ขาวเต็ม, hover = ขาวจาง,
// idle = ขาวโปร่ง (อ่านง่ายแต่ไม่เด่นเกินตัว active)

component TabItem inherits Rectangle {
    in property <int> tab-index;
    in property <string> title;
    in property <bool> active;
    in property <bool> is-pinned;
    in property <string> site-type;
    in property <bool> has-favicon;
    in property <image> favicon;
    in property <bool> is-drag-source;
    in property <length> slot-width: 120px;

    callback pressed(int);
    callback moved(int, length);
    callback released(int, length);
    callback select_tab(int);
    callback closed();

    width: root.slot-width;
    animate width { duration: 150ms; easing: ease-out; }
    height: 30px; /* Compact floating tab */

    // True when mouse is over the close button zone (right 22px of wide tab, or anywhere on narrow tab while hovered)
    property <bool> mouse-on-close: touch-area.has-hover && !root.is-pinned && (
        root.slot-width > 70px
            ? touch-area.mouse-x >= root.slot-width - 22px
            : true
    );

    // Visual container declared FIRST so touch-area (below) sits on top with stable has-hover
    visual_container := Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        opacity: root.is-drag-source ? 0.0 : 1.0;

        // เส้นคั่นแนวตั้งระหว่าง tab (สไตล์ Brave) — ซ่อนเมื่อ active หรือ hover
        if !root.active && !touch-area.has-hover : Rectangle {
            width: 1px;
            height: 15px;
            background: #FFFFFF33;
            x: parent.width - 1px;
            y: (parent.height - self.height) / 2;
        }

        background_capsule := Rectangle {
            x: 4px;
            y: 2px;
            width: parent.width - 8px;
            height: parent.height - 4px;
            border-radius: 7px;
            // active = แผ่นทึบจางๆ (เหมือน tab ที่เลือกใน Brave) ตัวอื่นโปร่งใส โผล่ตอน hover
            background:
                root.active ? #FFFFFF2B :
                touch-area.has-hover ? #FFFFFF17 : transparent;
            border-width: 0px;
            animate background { duration: 120ms; }
        }

        HorizontalLayout {
            // ชิดซ้าย: favicon → title → (spacer) → ปุ่มปิด ทางขวา
            padding-left: root.slot-width > 70px ? 14px : 4px;
            padding-right: root.slot-width > 70px ? 10px : 4px;
            spacing: root.slot-width > 70px ? 8px : 0px;
            // Removed alignment: start to let horizontal-stretch push the close button to the right

            if root.slot-width > 70px || !touch-area.has-hover : ProIcon {
                icon: root.has-favicon ? root.favicon : (
                    root.site-type == "brave" ? @image-url("icons/solar/shield.svg") :
                    root.site-type == "arc" ? @image-url("icons/solar/arc.svg") :
                    root.site-type == "google" ? @image-url("icons/solar/google.svg") :
                    @image-url("icons/solar/globe.svg")
                );
                icon-color: root.has-favicon ? #FFFFFF : (root.active ? #FFFFFF : (touch-area.has-hover ? #FFFFFFEC : #FFFFFFB3));
                fill-color: (!root.has-favicon && root.site-type == "google" && root.active) ? #FFFFFF : ((!root.has-favicon && root.site-type == "google") ? #FFFFFFB3 : transparent);
                icon-width: 13px;
                icon-height: 13px;
                stroke-width: 1.6px;
                y: (parent.height - self.height) / 2;
            }

            if root.slot-width > 70px : Text {
                text: root.title;
                color: root.active ? #FFFFFF : (touch-area.has-hover ? #FFFFFFEC : #FFFFFFB3);
                font-size: 11px;
                font-weight: root.active ? 600 : 500;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 1;
            }

            // Close button — visual only, NO nested TouchArea (click handled by touch-area via position check)
            if !root.is-pinned && (
                (root.slot-width > 70px && (root.active || touch-area.has-hover)) ||
                (root.slot-width <= 70px && touch-area.has-hover)
            ) : Rectangle {
                width: 15px;
                height: 15px;
                border-radius: 7px;
                background: root.mouse-on-close ? #FFFFFF2E : transparent;
                y: (parent.height - self.height) / 2;

                ProIcon {
                    icon: @image-url("icons/solar/cancel.svg");
                    icon-color: root.active ? #FFFFFF : (root.mouse-on-close ? #FFFFFF : #FFFFFFB3);
                    icon-width: 14px;
                    icon-height: 14px;
                    y: (parent.height - self.height) / 2;
                }
            }
        }
    }

    // touch-area declared LAST = highest z-order → always topmost → has-hover never stolen by close button
    touch-area := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: TabDrag.state.active ? grabbing :
                      root.is-pinned ? default :
                      root.mouse-on-close ? pointer : grab;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.pressed(root.tab-index);
                if (!root.mouse-on-close) {
                    root.select_tab(root.tab-index);
                }
            }
            if (event.kind == PointerEventKind.up) {
                if (TabDrag.state.active) {
                    // Drag reorder complete
                    root.released(root.tab-index, self.mouse-x - self.pressed-x);
                } else if (!root.is-pinned && root.mouse-on-close) {
                    // Close button click
                    root.closed();
                    TabDrag.state = { from: -1, to: -1, delta-x: 0px, active: false };
                } else {
                    // Clean click — already selected on down; just clean up state
                    TabDrag.state = { from: -1, to: -1, delta-x: 0px, active: false };
                }
            }
        }

        moved => {
            if (self.pressed && !root.is-pinned) {
                let dx = self.mouse-x - self.pressed-x;
                if (TabDrag.state.active) {
                    root.moved(root.tab-index, dx);
                } else if (Math.abs(dx) > 15px) {
                    root.moved(root.tab-index, dx);
                }
            }
        }
    }
}

component AddTabButton inherits Rectangle {
    callback activated();

    width: 26px;
    height: 26px;
    border-radius: 13px;
    background: touch-area.has-hover ? #FFFFFF22 : transparent;

    ProIcon {
        icon: @image-url("icons/solar/plus.svg");
        icon-color: touch-area.has-hover ? #FFFFFF : #FFFFFFC4;
        icon-width: 12px;
        icon-height: 12px;
        stroke-width: 1.6px;
        y: (parent.height - self.height) / 2;
    }

    touch-area := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activated(); }
    }
}

export component TabBar inherits Rectangle {
    in property <[TabInfo]> tabs;
    in property <bool> has-titlebar-spacing: true;

    callback back_clicked();
    callback forward_clicked();
    callback reload_clicked();
    callback select_tab(int);
    callback close_tab(int);
    callback new_tab();
    callback move_tab(int, int);
    callback start_drag_window();
    callback double_click_titlebar();

    height: 40px;
    background: transparent;

    property <length> available-width: root.width - (root.has-titlebar-spacing ? 100px : 20px) - 20px;
    property <length> max-tab-width: 130px;
    property <length> min-tab-width: 40px;
    
    // Max island width
    property <length> max-island-width: 800px;
    property <length> desired-island-width: root.tabs.length * root.max-tab-width + 48px;
    property <length> actual-island-width: Math.min(root.available-width, Math.min(root.max-island-width, root.desired-island-width));
    
    property <length> calculated-tab-width: root.tabs.length > 0 ? Math.max(
        root.min-tab-width,
        (root.actual-island-width - 48px) / root.tabs.length
    ) : root.max-tab-width;

    // Pure function to calculate sliding visual offset for reordering
    pure function tab-visual-offset(idx: int, from: int, to: int, delta-x: length, slot-width: length) -> length {
        if from < 0 || !TabDrag.state.active {
            0px
        } else if idx == from {
            delta-x
        } else if to > from {
            if idx > from && idx <= to {
                -slot-width
            } else {
                0px
            }
        } else if to < from {
            if idx < from && idx >= to {
                slot-width
            } else {
                0px
            }
        } else {
            0px
        }
    }

    pure function target-index(from: int, delta-x: length) -> int {
        if from < 0 {
            -1
        } else if root.tabs.length <= 0 {
            from
        } else {
            Math.max(0, Math.min(root.tabs.length - 1, from + Math.round(delta-x / root.calculated-tab-width)))
        }
    }

    // Main window drag area for the entire transparent bar
    TouchArea {
        width: parent.width;
        height: parent.height;
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                root.start_drag_window();
            }
        }
        double-clicked => { root.double_click_titlebar(); }
    }

    tab-flickable := Flickable {
        width: parent.width - (root.has-titlebar-spacing ? 80px : 12px) - 12px;
        x: root.has-titlebar-spacing ? 80px : 12px;
        height: 30px;
        y: 5px; // Center the 30px tabs within the 40px bar
        interactive: false;
        viewport-width: Math.max(root.tabs.length * root.calculated-tab-width + 36px, tab-flickable.width);

        Rectangle {
            width: Math.max(root.tabs.length * root.calculated-tab-width + 36px, tab-flickable.width);
            height: parent.height;

            TouchArea {
                width: parent.width;
                height: parent.height;
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down) {
                        TabDrag.window-drag-mode = false;
                    }
                }
                moved => {
                    if (self.pressed && !TabDrag.window-drag-mode && !TabDrag.state.active) {
                        let dx = self.mouse-x - self.pressed-x;
                        let dy = self.mouse-y - self.pressed-y;
                        if (Math.abs(dx) > 15px || Math.abs(dy) > 15px) {
                            TabDrag.window-drag-mode = true;
                            root.start_drag_window();
                        }
                    }
                }
                double-clicked => { root.double_click_titlebar(); }
            }

            for tab[idx] in root.tabs: TabItem {
                x: idx * root.calculated-tab-width + root.tab-visual-offset(idx, TabDrag.state.from, TabDrag.state.to, TabDrag.state.delta-x, root.calculated-tab-width);
                y: (parent.height - self.height) / 2;
                
                tab-index: idx;
                title: tab.title;
                active: tab.active;
                is-pinned: tab.is_pinned;
                site-type: tab.site_type;
                has-favicon: tab.has_favicon;
                favicon: tab.favicon;
                is-drag-source: TabDrag.state.active && TabDrag.state.from == idx;
                slot-width: root.calculated-tab-width;

                pressed(index) => {
                    TabDrag.state = {
                        from: index,
                        to: index,
                        delta-x: 0px,
                        active: false,
                    };
                }
                moved(index, delta-x) => {
                    if (TabDrag.state.from == index) {
                        let slot-w = root.calculated-tab-width;
                        let min-x = -index * slot-w;
                        let max-x = (root.tabs.length - 1 - index) * slot-w;
                        let clamped-delta = Math.max(min-x, Math.min(max-x, delta-x));
                        
                        if (!TabDrag.state.active && Math.abs(delta-x) > 15px) {
                            TabDrag.state = {
                                from: index,
                                to: index,
                                delta-x: clamped-delta,
                                active: true,
                            };
                        } else if (TabDrag.state.active) {
                            TabDrag.state = {
                                from: index,
                                to: root.target-index(index, clamped-delta),
                                delta-x: clamped-delta,
                                active: true,
                            };
                        }
                    }
                }
                released(index, delta-x) => {
                    if (TabDrag.state.from == index) {
                        if (!TabDrag.state.active) {
                            // Already selected on down
                        } else {
                            // Drag path — resolve final position
                            let slot-w = root.calculated-tab-width;
                            let min-x = -index * slot-w;
                            let max-x = (root.tabs.length - 1 - index) * slot-w;
                            let clamped = Math.max(min-x, Math.min(max-x, delta-x));
                            let to-idx = root.target-index(index, clamped);
                            if (TabDrag.state.from != to-idx) {
                                root.move_tab(TabDrag.state.from, to-idx);
                            } else {
                                root.select_tab(index);
                            }
                        }
                        TabDrag.state = { from: -1, to: -1, delta-x: 0px, active: false };
                    }
                }
                select_tab(index) => { root.select_tab(index); }
                closed => { root.close_tab(idx); }

                // Smooth sliding when static positions change, disabled on release to prevent layout fights
                animate x {
                    duration: (TabDrag.state.active && TabDrag.state.from != idx) ? 150ms : 0ms;
                    easing: ease-out;
                }
            }

            if TabDrag.state.active && TabDrag.state.from >= 0 && TabDrag.state.from < root.tabs.length : TabGhost {
                x: TabDrag.state.from * root.calculated-tab-width + TabDrag.state.delta-x;
                y: (parent.height - self.height) / 2;
                title: root.tabs[TabDrag.state.from].title;
                site-type: root.tabs[TabDrag.state.from].site_type;
                active: root.tabs[TabDrag.state.from].active;
                has-favicon: root.tabs[TabDrag.state.from].has_favicon;
                favicon: root.tabs[TabDrag.state.from].favicon;
                slot-width: root.calculated-tab-width;
            }

            AddTabButton {
                x: root.tabs.length * root.calculated-tab-width + 4px;
                y: (parent.height - self.height) / 2;
                activated => { root.new_tab(); }

                animate x { duration: 150ms; easing: ease-out; }
            }
        }
    }
}
