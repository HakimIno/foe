import { ProIcon, MinimalButton, MinimalIconButton } from "common.slint";

export struct TabInfo {
    title: string,
    url: string,
    active: bool,
    is_pinned: bool,
    site_type: string,
}

export struct DownloadItem {
    name: string,
    progress: float,
    status: string,
}

component SidebarTab inherits Rectangle {
    in property <string> title;
    in property <bool> active;
    in property <bool> is-pinned;
    
    callback clicked();
    callback closed();

    height: 36px;
    border-radius: 4px;
    background: root.active ? #1E1E20 : (touch-area.has-hover ? #141416 : transparent);
    border-width: 1px;
    border-color: root.active ? #2D2D30 : transparent;

    animate background { duration: 100ms; }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;

        if root.active: Rectangle {
            width: 4px;
            height: 12px;
            background: #D4D4D8;
            border-radius: 2px;
            y: (parent.height - self.height) / 2;
        }

        ProIcon {
            icon: @image-url("icons/solar/document.svg");
            icon-color: root.active ? #FFFFFF : #71717A;
            icon-width: 14px;
            icon-height: 14px;
            stroke-width: 1.6px;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: root.title;
            color: root.active ? #FFFFFF : #A0A0AA;
            font-size: 13px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    if touch-area.has-hover && !root.is-pinned : Rectangle {
        x: parent.width - 28px;
        y: (parent.height - 18px) / 2;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        background: touch-close.has-hover ? #2E2E33 : transparent;

        ProIcon {
            icon: @image-url("icons/solar/cancel.svg");
            icon-color: #A0A0AA;
            icon-width: 10px;
            icon-height: 10px;
            stroke-width: 1.5px;
        }

        touch-close := TouchArea {
            clicked => { root.closed(); }
        }
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component Sidebar inherits Rectangle {
    in property <[TabInfo]> tabs;
    in property <[DownloadItem]> downloads;
    in property <bool> show-downloader-panel;
    in property <int> blocked-count;
    in property <bool> shields-active;

    callback select_tab(int);
    callback close_tab(int);
    callback new_tab();
    callback toggle_downloader();

    width: 230px;
    background: #0B0B0C;
    
    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        height: parent.height;
        background: #1E1E20;
    }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        HorizontalLayout {
            alignment: space-between;
            height: 32px;

            HorizontalLayout {
                spacing: 8px;
                Rectangle {
                    width: 24px;
                    height: 24px;
                    border-radius: 12px;
                    background: #1E1E20;
                    border-width: 1px;
                    border-color: #2D2D30;
                    
                    ProIcon {
                        icon: @image-url("icons/solar/person.svg");
                        icon-color: #D4D4D8;
                        icon-width: 14px;
                        icon-height: 14px;
                        stroke-width: 1.6px;
                    }
                }
                Text {
                    text: "Personal";
                    color: #E4E4E7;
                    font-size: 13px;
                    font-weight: 500;
                    vertical-alignment: center;
                }
            }

            MinimalIconButton {
                icon: @image-url("icons/solar/menu.svg");
                clicked => { root.toggle_downloader(); }
            }
        }

        MinimalButton {
            text: "+ New Tab";
            clicked => { root.new_tab(); }
        }

        Text {
            text: "WORKSPACES";
            color: #52525B;
            font-size: 10px;
            font-weight: 700;
        }

        VerticalLayout {
            spacing: 2px;
            for tab[idx] in root.tabs: SidebarTab {
                title: tab.title;
                active: tab.active;
                is-pinned: tab.is_pinned;
                clicked => { root.select_tab(idx); }
                closed => { root.close_tab(idx); }
            }
        }

        Rectangle {}

        if root.show-downloader-panel : Rectangle {
            height: 140px;
            background: #141416;
            border-radius: 6px;
            border-width: 1px;
            border-color: #242427;
            
            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "Downloads";
                        color: #E4E4E7;
                        font-size: 11px;
                        font-weight: 600;
                    }
                    Text {
                        text: "Hide";
                        color: #71717A;
                        font-size: 11px;
                        touch-hide := TouchArea {
                            clicked => { root.toggle_downloader(); }
                        }
                    }
                }

                for dl in root.downloads : VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: dl.name;
                        color: #A0A0AA;
                        font-size: 11px;
                        overflow: elide;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            background: #242427;
                            height: 4px;
                            border-radius: 2px;
                            width: 130px;
                            Rectangle {
                                background: #FFFFFF;
                                width: parent.width * dl.progress;
                                height: 4px;
                                border-radius: 2px;
                                x: 0;
                            }
                        }
                        Text {
                            text: "72%";
                            color: #FFFFFF;
                            font-size: 10px;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 40px;
            background: #141416;
            border-radius: 6px;
            border-width: 1px;
            border-color: #242427;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 8px;
                    ProIcon {
                        icon: @image-url("icons/solar/shield.svg");
                        icon-color: root.shields-active ? #FFFFFF : #71717A;
                        icon-width: 14px;
                        icon-height: 14px;
                        stroke-width: 1.6px;
                        y: (parent.height - self.height) / 2;
                    }
                    Text {
                        text: "Shielded Block";
                        color: #71717A;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                Text {
                    text: root.blocked-count + "";
                    color: root.shields-active ? #FFFFFF : #71717A;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }
    }
}
