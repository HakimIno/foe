import { ProIcon, MinimalButton, MinimalIconButton } from "common.slint";
import { Theme } from "theme.slint";

export struct TabInfo {
    id: int,
    title: string,
    url: string,
    active: bool,
    is_pinned: bool,
    site_type: string,
    has_favicon: bool,
    favicon: image,
    loading: bool,
}

export struct DownloadItem {
    name: string,
    progress: float,
    status: string,
}

component SidebarTab inherits Rectangle {
    in property <string> title;
    in property <bool> active;
    in property <bool> is-pinned;
    in property <string> site-type;
    in property <bool> has-favicon;
    in property <image> favicon;
    
    callback clicked();
    callback closed();

    height: 36px;
    border-radius: 4px;
    background: root.active ? Theme.surface-active : (touch-area.has-hover ? Theme.surface-hover : transparent);
    border-width: 1px;
    border-color: root.active ? Theme.surface-border : transparent;

    animate background { duration: 100ms; }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;

        if root.active: Rectangle {
            width: 4px;
            height: 12px;
            background: Theme.selection;
            border-radius: 2px;
            y: (parent.height - self.height) / 2;
        }

        ProIcon {
            icon: root.has-favicon ? root.favicon : (
                root.site-type == "brave" ? @image-url("icons/solar/shield.svg") :
                root.site-type == "arc" ? @image-url("icons/solar/arc.svg") :
                root.site-type == "google" ? @image-url("icons/solar/google.svg") :
                @image-url("icons/solar/document.svg")
            );
            icon-color: root.has-favicon ? transparent : (root.active ? Theme.text : Theme.text-muted);
            fill-color: (!root.has-favicon && root.site-type == "google") ? Theme.text : transparent;
            icon-width: 14px;
            icon-height: 14px;
            stroke-width: 1.6px;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: root.title;
            color: root.active ? Theme.text : Theme.text-secondary;
            font-size: 13px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    if touch-area.has-hover && !root.is-pinned : Rectangle {
        x: parent.width - 28px;
        y: (parent.height - 18px) / 2;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        background: touch-close.has-hover ? Theme.surface-border : transparent;

        ProIcon {
            icon: @image-url("icons/solar/cancel.svg");
            icon-color: Theme.text-secondary;
            icon-width: 10px;
            icon-height: 10px;
            stroke-width: 1.5px;
        }

        touch-close := TouchArea {
            clicked => { root.closed(); }
        }
    }

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component Sidebar inherits Rectangle {
    in property <[TabInfo]> tabs;
    in property <[DownloadItem]> downloads;
    in property <bool> show-downloader-panel;
    in property <int> blocked-count;
    in property <bool> shields-active;

    callback select_tab(int);
    callback close_tab(int);
    callback new_tab();
    callback toggle_downloader();

    width: 230px;
    background: Theme.sidebar-bg;

    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        height: parent.height;
        background: Theme.sidebar-divider;
    }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        HorizontalLayout {
            alignment: space-between;
            height: 32px;

            HorizontalLayout {
                spacing: 8px;
                Rectangle {
                    width: 24px;
                    height: 24px;
                    border-radius: 12px;
                    background: Theme.surface-active;
                    border-width: 1px;
                    border-color: Theme.surface-border;

                    ProIcon {
                        icon: @image-url("icons/solar/person.svg");
                        icon-color: Theme.text-secondary;
                        icon-width: 14px;
                        icon-height: 14px;
                        stroke-width: 1.6px;
                    }
                }
                Text {
                    text: "Personal";
                    color: Theme.text;
                    font-size: 13px;
                    font-weight: 500;
                    vertical-alignment: center;
                }
            }

            MinimalIconButton {
                icon: @image-url("icons/solar/menu.svg");
                clicked => { root.toggle_downloader(); }
            }
        }

        MinimalButton {
            text: "+ New Tab";
            clicked => { root.new_tab(); }
        }

        Text {
            text: "WORKSPACES";
            color: Theme.text-faint;
            font-size: 10px;
            font-weight: 700;
        }

        VerticalLayout {
            spacing: 2px;
            for tab[idx] in root.tabs: SidebarTab {
                title: tab.title;
                active: tab.active;
                is-pinned: tab.is_pinned;
                site-type: tab.site_type;
                has-favicon: tab.has_favicon;
                favicon: tab.favicon;
                clicked => { root.select_tab(idx); }
                closed => { root.close_tab(idx); }
            }
        }

        Rectangle {}

        if root.show-downloader-panel : Rectangle {
            height: 140px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.surface-border-2;
            
            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "Downloads";
                        color: Theme.text;
                        font-size: 11px;
                        font-weight: 600;
                    }
                    Text {
                        text: "Hide";
                        color: Theme.text-muted;
                        font-size: 11px;
                        touch-hide := TouchArea {
                            clicked => { root.toggle_downloader(); }
                        }
                    }
                }

                for dl in root.downloads : VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: dl.name;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        overflow: elide;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            background: Theme.surface-border-2;
                            height: 4px;
                            border-radius: 2px;
                            width: 130px;
                            Rectangle {
                                background: Theme.text;
                                width: parent.width * dl.progress;
                                height: 4px;
                                border-radius: 2px;
                                x: 0;
                            }
                        }
                        Text {
                            text: "72%";
                            color: Theme.text;
                            font-size: 10px;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 40px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.surface-border-2;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 8px;
                    ProIcon {
                        icon: @image-url("icons/solar/shield.svg");
                        icon-color: root.shields-active ? Theme.text : Theme.text-muted;
                        icon-width: 14px;
                        icon-height: 14px;
                        stroke-width: 1.6px;
                        y: (parent.height - self.height) / 2;
                    }
                    Text {
                        text: "Shielded Block";
                        color: Theme.text-muted;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                Text {
                    text: root.blocked-count + "";
                    color: root.shields-active ? Theme.text : Theme.text-muted;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }
    }
}
